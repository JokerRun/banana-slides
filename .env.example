# Banana Slides 环境变量示例
# 配置模式：env-only。修改 .env / secrets 后需要重启后端服务。
# 建议：只取消你实际使用的 provider / 服务配置，避免无关密钥混在一起。


# =============================================================================
# 1. 应用启动 / 服务基础配置
# =============================================================================

# 运行环境：development / production
FLASK_ENV=production

# 后端监听端口；本地默认 5000
BACKEND_PORT=5000

# 日志等级：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Flask session secret。生产环境必须改成随机长字符串。
SECRET_KEY=your-secret-key-change-this-in-production

# 数据库连接；默认不填时使用 backend/instance/database.db
# DATABASE_URL=sqlite:///backend/instance/database.db

# 前端地址：OAuth callback 后端重定向目标
# dev: http://localhost:3000；prod: https://your-domain.com
FRONTEND_URL=http://localhost:3000

# CORS 允许来源。生产环境不要用 *，多个地址用逗号分隔。
CORS_ORIGINS=http://localhost:3000

# HTTPS 部署时设为 true；本地 HTTP 保持 false
SESSION_COOKIE_SECURE=false


# =============================================================================
# 2. AI Provider（文本/大纲/描述生成）
# =============================================================================

# 只决定“文本类 AI 调用”默认走哪个 SDK。
# 可选值：gemini / openai
AI_PROVIDER_FORMAT=gemini

# 文本模型默认值；按 provider 填对应模型名。
TEXT_MODEL=gemini-3-flash-preview

# --- Gemini 文本 Provider（AI_PROVIDER_FORMAT=gemini）---
GOOGLE_API_KEY=your-google-api-key
GOOGLE_API_BASE=https://generativelanguage.googleapis.com
# 代理示例：GOOGLE_API_BASE=https://aihubmix.com/gemini

# Gemini SDK 超时/重试；默认 300 秒 / 2 次
GENAI_TIMEOUT=300.0
GENAI_MAX_RETRIES=2

# --- OpenAI 文本 Provider（AI_PROVIDER_FORMAT=openai）---
# 也会被 IMAGE_PROVIDER_FORMAT=openai 复用；若文本不用 OpenAI 但图片用，也需要填写。
OPENAI_API_KEY=your-openai-or-compatible-api-key
OPENAI_API_BASE=https://api.openai.com/v1
# 代理示例：OPENAI_API_BASE=https://aihubmix.com/v1

# OpenAI SDK 超时/重试；默认 300 秒 / 2 次
OPENAI_TIMEOUT=300.0
OPENAI_MAX_RETRIES=2


# =============================================================================
# 3. Image Provider（图片生成 / PPT restyle）
# =============================================================================

# 图片 provider 可独立覆盖 AI_PROVIDER_FORMAT。
# 不填时默认跟随 AI_PROVIDER_FORMAT。
# 可选值：gemini / openai
# 常见组合：AI_PROVIDER_FORMAT=gemini + IMAGE_PROVIDER_FORMAT=openai
IMAGE_PROVIDER_FORMAT=gemini

# 图片模型默认值；Gemini 图片 provider 会直接使用它。
IMAGE_MODEL=gemini-3-pro-image-preview

# 默认图片规格；任务层默认使用 16:9 / 2K
DEFAULT_ASPECT_RATIO=16:9
DEFAULT_RESOLUTION=2K

# 图像思考级别（Gemini image）：none / minimal / high；默认 none
IMAGE_THINKING_LEVEL=none


# -----------------------------------------------------------------------------
# 3A. OpenAI SDK Image Backend（IMAGE_PROVIDER_FORMAT=openai）
# -----------------------------------------------------------------------------

# 只决定“图片调用”使用 OpenAI SDK 的哪种后端。
# proxy   : OpenAI-compatible proxy，默认走 Responses API image_generation tool
# azure   : Azure OpenAI Responses API + image_generation tool
# chatgpt : 本地 ChatGPT/Codex auth.json，建议仅本地调试使用
# 可选值：proxy / azure / chatgpt
OPENAI_IMAGE_BACKEND=proxy

# 图片调用模式：responses / chat。默认 responses，支持 restyle edit 多轮上下文。
# chat 是 legacy proxy 兼容模式，只建议在代理不支持 Responses API 时使用。
OPENAI_IMAGE_MODE=responses

# --- proxy 示例 ---
# IMAGE_PROVIDER_FORMAT=openai
# OPENAI_IMAGE_BACKEND=proxy
# OPENAI_IMAGE_MODE=responses
# OPENAI_API_KEY=your-proxy-api-key
# OPENAI_API_BASE=https://aihubmix.com/v1
# OPENAI_RESPONSES_MODEL=gpt-5.4
# OPENAI_IMAGE_MODEL=gpt-image-2

# --- legacy proxy chat-completions 示例（仅代理不支持 Responses API 时使用）---
# IMAGE_PROVIDER_FORMAT=openai
# OPENAI_IMAGE_BACKEND=proxy
# OPENAI_IMAGE_MODE=chat
# OPENAI_API_KEY=your-proxy-api-key
# OPENAI_API_BASE=https://aihubmix.com/v1
# IMAGE_MODEL=gemini-3-pro-image-preview

# --- azure 示例：仍使用 openai.OpenAI，不使用 AzureOpenAI client ---
# IMAGE_PROVIDER_FORMAT=openai
# OPENAI_IMAGE_BACKEND=azure
# OPENAI_IMAGE_MODE=responses
# OPENAI_API_KEY=your-azure-openai-api-key
# OPENAI_API_BASE=https://your-resource.cognitiveservices.azure.com/openai/v1
# OPENAI_API_VERSION=preview
# OPENAI_RESPONSES_MODEL=gpt-5.4
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_IMAGE_DEPLOYMENT=gpt-image-2

# Responses 图片工具参数；OPENAI_IMAGE_MODE=responses 时使用
OPENAI_API_VERSION=preview
OPENAI_RESPONSES_MODEL=
OPENAI_IMAGE_MODEL=
OPENAI_IMAGE_DEPLOYMENT=
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_OUTPUT_FORMAT=png

# --- chatgpt 示例（本地调试）---
# IMAGE_PROVIDER_FORMAT=openai
# OPENAI_IMAGE_BACKEND=chatgpt
# OPENAI_IMAGE_MODE=responses
# OPENAI_RESPONSES_MODEL=gpt-5.4
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_AUTH_JSON=/Users/you/.codex/auth.json
OPENAI_AUTH_JSON=


# =============================================================================
# 4. 推理与输出默认值
# =============================================================================

# 文本推理开关；默认关闭。仅对支持 thinking/reasoning 的 provider 有意义。
ENABLE_TEXT_REASONING=false
TEXT_THINKING_BUDGET=1024

# 输出语言：zh / ja / en / auto
OUTPUT_LANGUAGE=zh


# =============================================================================
# 5. 并发与 Restyle 调优
# =============================================================================

# 页面描述/图片生成并发数；过高可能触发 provider 限流。
MAX_DESCRIPTION_WORKERS=5
MAX_IMAGE_WORKERS=8

# Restyle 编辑上下文图片预算；通常无需修改。
RESTYLE_EDIT_MAX_PRUNABLE_IMAGES=6
RESTYLE_EDIT_MAX_TOTAL_IMAGES=8

# Restyle debug artifacts；排查上下文/图片输入问题时再开启。
DEBUG_RESTYLE_CONTEXT=false
# RESTYLE_EDIT_DEBUG_DIR=debug/restyle-context


# =============================================================================
# 6. 文件解析 / OCR / 图片修复外部服务
# =============================================================================

# MinerU 文件解析服务；用于 PDF/DOC/PPT 等参考文件解析。
# Token 获取：https://mineru.net/apiManage/token ，注意有效期。
MINERU_TOKEN=your-mineru-token
MINERU_API_BASE=https://mineru.net

# 解析文件中的图片 caption 模型。
IMAGE_CAPTION_MODEL=gemini-3-flash-preview

# 可编辑 PPTX 导出 / OCR / 局部修复相关。
BAIDU_OCR_API_KEY=your-baidu-api-key

# 单张图片修复 provider：gemini / volcengine
INPAINTING_PROVIDER=gemini

# 火山引擎图片修复；仅 INPAINTING_PROVIDER=volcengine 时需要。
# VOLCENGINE_ACCESS_KEY=your-volcengine-access-key
# VOLCENGINE_SECRET_KEY=your-volcengine-secret-key
VOLCENGINE_INPAINTING_TIMEOUT=60
VOLCENGINE_INPAINTING_MAX_RETRIES=3


# =============================================================================
# 7. OAuth 登录配置
# =============================================================================

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:5000/api/auth/oauth/github/callback

# --- Azure China 21V OAuth（可选，不是 Azure OpenAI）---
# 详细步骤见 docs/guides/oauth-setup.md
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_SECRET=your-azure-client-secret-value
# AZURE_REDIRECT_URI=http://localhost:5000/api/auth/oauth/azure/callback
# 单租户：将 {tenant-id} 替换为目录(租户) ID；多租户：使用 common
# AZURE_AUTH_URL=https://login.partner.microsoftonline.cn/{tenant-id}/oauth2/v2.0/authorize
# AZURE_TOKEN_URL=https://login.partner.microsoftonline.cn/{tenant-id}/oauth2/v2.0/token
# AZURE_USER_INFO_URL=https://microsoftgraph.chinacloudapi.cn/v1.0/me


# =============================================================================
# 8. 镜像源配置（国内网络问题时再启用）
# =============================================================================

# Docker Hub 镜像源（注意末尾斜杠）
# DOCKER_REGISTRY=docker.1ms.run/

# GitHub Container Registry 镜像源（注意末尾斜杠）
# GHCR_REGISTRY=ghcr.nju.edu.cn/

# Debian apt 镜像源
# APT_MIRROR=mirrors.aliyun.com

# PyPI 镜像源
# PYPI_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple

# npm 镜像源（注意末尾斜杠）
# NPM_REGISTRY=https://registry.npmmirror.com/
